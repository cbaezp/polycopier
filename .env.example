# Polymarket Copy Trading Bot - Environment Configuration
# Copy this file to .env and fill in your values.
# The bot will prompt you interactively on first run if any required fields are missing.

# -- Wallet Credentials --------------------------------------------------------

# Private key for the wallet that SIGNS and EXECUTES the copy trades.
# Supports 0x-prefixed or plain hex format.
PRIVATE_KEY="your-private-key-here"

# Funder address: the wallet that holds the USDC used to fund orders.
# For Magic (email) wallets this is your proxy address.
# For browser wallets (MetaMask) this is your GnosisSafe/proxy contract address.
# Find it at: polymarket.com → Profile → Address
FUNDER_ADDRESS="0xYourFunderAddressHere"

# -- Copy Targets --------------------------------------------------------------

# Comma-separated list of Polymarket proxy wallet addresses to monitor and copy.
TARGET_WALLETS="0xTargetWallet1,0xTargetWallet2"

# -- Trade Execution Limits ----------------------------------------------------

# Maximum slippage allowed from the copied trade's price (as a decimal ratio).
# 0.02 = allow up to 2% worse price than the target's execution price.
MAX_SLIPPAGE_PCT="0.02"

# Maximum USD to spend per copied trade.
# Position scanner entries are also capped to this amount.
MAX_TRADE_SIZE_USD="2.00"

# Ignore live trades older than this many seconds (staleness filter).
# Prevents acting on delayed data during network hiccups.
MAX_DELAY_SECONDS="10"

# -- Position Scanner (Open Position Mirroring) --------------------------------

# Skip entering an existing target position if it is already this % underwater.
# Compares target's average entry price vs current market price.
# 0.40 = skip if the position is 40% or more in the red.
# Lower = more conservative (e.g. 0.20 skips anything 20%+ down).
MAX_COPY_LOSS_PCT="0.40"

# Skip catch-up entries where the target is already this far in profit.
# Prevents chasing positions that already moved -- slippage eats any edge.
# 0.05 = skip if target is up 5%+. Set higher (e.g. 0.20) to copy more aggressively.
MAX_COPY_GAIN_PCT="0.05"

# Price range filter for catch-up entries from the position scanner.
# Only enter a target's open position if its current price is within this window.
#
# MIN_ENTRY_PRICE: filters out near-zero dust tokens (default 0.02).
# MAX_ENTRY_PRICE: filters out near-certain outcomes.
#   - Default (0.998) allows near-certainty NO positions (e.g. curPrice = 0.9985).
#   - Set to 0.95 for balanced-market traders where high-price entries carry too much risk.
MIN_ENTRY_PRICE="0.02"
MAX_ENTRY_PRICE="0.999"

# -- Sizing Mode ---------------------------------------------------------------

# How each copied trade is sized. Options:
#   self_pct   (default) -- bet COPY_SIZE_PCT * current_balance per trade
#   target_usd           -- mirror the target's exact dollar amount (capped at MAX_TRADE_SIZE_USD)
#   fixed                -- always bet MAX_TRADE_SIZE_USD
SIZING_MODE="self_pct"

# Fraction of our balance to bet per trade when SIZING_MODE=self_pct.
# 0.15 = 15% of current balance. Capped by MAX_TRADE_SIZE_USD.
COPY_SIZE_PCT="0.15"

# -- Position Scanner ----------------------------------------------------------

# Maximum positions the scanner will queue per cycle (default 1 = conservative).
# Raise to 2–3 to enter multiple fresh opportunities in a single scan pass.
# Note: higher values consume balance faster during burst activity.
SCAN_MAX_ENTRIES_PER_CYCLE="1"

# -- Order Execution -----------------------------------------------------------

# Fee buffer applied to SELL order size: sell_size = held_size * SELL_FEE_BUFFER.
# Default 0.97 absorbs the Polymarket CLOB fee (~2-3%). Adjust if fees change.
SELL_FEE_BUFFER="0.97"

# -- Ledger Retention ----------------------------------------------------------

# Days to retain closed ledger entries before pruning at startup.
# Set to 0 to disable pruning (ledger will grow indefinitely).
LEDGER_RETENTION_DAYS="90"

# -- Risk Engine ---------------------------------------------------------------

# Maximum total USD the bot may trade in a single UTC day. 0 = disabled.
# Includes both BUY and SELL side volume. Resets at UTC midnight.
MAX_DAILY_VOLUME_USD="0"

# Number of consecutive BUY losses that trigger a cooldown pause. 0 = disabled.
# A "loss" is recorded when the order watcher cancels a GTC order because the
# target's PnL dropped past MAX_COPY_LOSS_PCT.
MAX_CONSECUTIVE_LOSSES="0"

# Seconds to pause trading after hitting MAX_CONSECUTIVE_LOSSES. Default 300 (5 min).
LOSS_COOLDOWN_SECS="300"

